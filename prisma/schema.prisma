generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  STEWARD
}

enum CategoryType {
  FOOD
  BEVERAGE
  COMBO
  DESSERT
  SNACK
  CUSTOM
}

//////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  role          UserRole   @default(CASHIER)
  password      String

  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdCategories Category[] @relation("CategoryCreatedBy")
  updatedCategories Category[] @relation("CategoryUpdatedBy")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([restaurantId, role])
}

//////////////////////////////////////////////////
// RESTAURANT
//////////////////////////////////////////////////

model Restaurant {
  id         String     @id @default(cuid())
  name       String

  users      User[]
  categories Category[]
  menuItems  MenuItem[]

  createdAt  DateTime @default(now())
}

//////////////////////////////////////////////////
// CATEGORY
//////////////////////////////////////////////////

model Category {
  id           String       @id @default(cuid())
  name         String
  description  String?
  type         CategoryType
  isActive     Boolean      @default(true)
  sortOrder    Int          @default(0)

  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  menuItems    MenuItem[]   // ✅ correct placement

  createdById  String?
  updatedById  String?

  createdBy    User? @relation("CategoryCreatedBy", fields: [createdById], references: [id])
  updatedBy    User? @relation("CategoryUpdatedBy", fields: [updatedById], references: [id])

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([name, restaurantId])
  @@index([restaurantId, isActive, sortOrder])
}

//////////////////////////////////////////////////
// MENU ITEM
//////////////////////////////////////////////////

model MenuItem {
  id            String   @id @default(cuid())
  name          String
  description   String?

  image         String?

  isAvailable   Boolean  @default(true)
  isVeg         Boolean  @default(false)
  isDeleted     Boolean  @default(false)

  basePrice     Float?

  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  categoryId    String
  category      Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  variations    Variation[]
  addonGroups   AddonGroup[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([restaurantId, categoryId, isAvailable])
  @@index([restaurantId, name])
}

//////////////////////////////////////////////////
// VARIATIONS
//////////////////////////////////////////////////

model Variation {
  id          String  @id @default(cuid())
  name        String
  price       Float

  sku         String?
  isDefault   Boolean @default(false)

  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([menuItemId])
}

//////////////////////////////////////////////////
// ADDON GROUP
//////////////////////////////////////////////////

model AddonGroup {
  id          String  @id @default(cuid())
  name        String

  isRequired  Boolean @default(false)
  maxSelect   Int?

  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  addons      Addon[]

  createdAt   DateTime @default(now())

  @@index([menuItemId])
}

//////////////////////////////////////////////////
// ADDON (MISSING FIX)
//////////////////////////////////////////////////

model Addon {
  id            String  @id @default(cuid())
  name          String
  price         Float

  addonGroupId  String
  addonGroup    AddonGroup @relation(fields: [addonGroupId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@index([addonGroupId])
}